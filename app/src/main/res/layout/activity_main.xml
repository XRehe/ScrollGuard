<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Üst boşluk -->
        <Space
            android:layout_width="match_parent"
            android:layout_height="48dp" />

        <!-- Logo / İkon alanı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛡️"
            android:textSize="72sp"
            android:gravity="center" />

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Uygulama adı -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ScrollGuard"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:letterSpacing="0.05"
            android:gravity="center" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reels &amp; Shorts Engelleyici"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp"
            android:gravity="center" />

        <Space android:layout_width="match_parent" android:layout_height="48dp" />

        <!-- Ana toggle kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="24dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="28dp"
                android:gravity="center">

                <!-- Durum metni (büyük) -->
                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="😴 Devre Dışı"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/inactive_color"
                    android:gravity="center" />

                <TextView
                    android:id="@+id/tvSubStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Toggle ile başlat"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center"
                    android:layout_marginTop="6dp" />

                <Space android:layout_width="match_parent" android:layout_height="28dp" />

                <!-- Büyük Toggle Butonu -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/toggleSwitch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:scaleX="1.6"
                    android:scaleY="1.6"
                    app:thumbTint="@color/white"
                    app:trackTint="@color/toggle_track_selector" />

                <Space android:layout_width="match_parent" android:layout_height="12dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Koru"
                    android:textSize="13sp"
                    android:textColor="@color/text_secondary" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Space android:layout_width="match_parent" android:layout_height="16dp" />

        <!-- Süre Ayarı Kartı -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="🛡️ Koruma Süresi"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <Space android:layout_width="match_parent" android:layout_height="12dp" />

                <!-- Süre Seçme Combo Box (Dropdown) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTimerMode"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Bir süre seçin"
                    app:boxStrokeColor="@color/accent_purple"
                    app:hintTextColor="@color/text_secondary">

                    <AutoCompleteTextView
                        android:id="@+id/actvTimerMode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:textColor="@color/text_primary"
                        android:padding="16dp" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Özel Süre Seçici (Alarm/Kaydırmalı Stil) -->
                <LinearLayout
                    android:id="@+id/llCustomPicker"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="16dp"
                    android:visibility="gone"
                    android:gravity="center">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center">

                        <!-- GÜN -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Gün" android:textSize="10sp" android:textColor="@color/text_secondary" />
                            <NumberPicker
                                android:id="@+id/npDays"
                                android:layout_width="50dp"
                                android:layout_height="120dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="8dp" />

                        <!-- SAAT -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Saat" android:textSize="10sp" android:textColor="@color/text_secondary" />
                            <NumberPicker
                                android:id="@+id/npHours"
                                android:layout_width="50dp"
                                android:layout_height="120dp" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=":"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:layout_marginHorizontal="4dp"
                            android:layout_marginTop="8dp" />

                        <!-- DAKİKA -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Dakika" android:textSize="10sp" android:textColor="@color/text_secondary" />
                            <NumberPicker
                                android:id="@+id/npMinutes"
                                android:layout_width="50dp"
                                android:layout_height="120dp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <Space android:layout_width="match_parent" android:layout_height="12dp" />

                <TextView
                    android:id="@+id/tvTimerInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sonsuz koruma seçili"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:gravity="center" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Space android:layout_width="match_parent" android:layout_height="20dp" />

        <!-- Erişilebilirlik ayarları butonu (sadece izin yokken göster) -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOpenSettings"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="⚙️  Erişilebilirlik İznini Ver"
            android:textSize="15sp"
            android:visibility="gone"
            app:backgroundTint="@color/accent_purple"
            app:cornerRadius="16dp" />

        <Space android:layout_width="match_parent" android:layout_height="24dp" />

        <!-- Alt bilgi kartı: engellenen uygulamalar -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/card_background"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Engellenen İçerikler"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <Space android:layout_width="match_parent" android:layout_height="12dp" />

                <!-- Uygulama listesi -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="📸  Instagram Reels" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/active_color" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="▶️  YouTube Shorts" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/active_color" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="🎵  TikTok" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/active_color" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="👻  Snapchat Spotlight" android:textColor="@color/text_secondary" android:textSize="13sp"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="✓" android:textColor="@color/active_color" android:textSize="13sp"/>
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Space android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
